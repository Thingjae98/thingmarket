# Supabase 설정 (https://supabase.com/dashboard/project/<id>/settings/general)
SUPABASE_URL=https://your-project-id.supabase.co

# Settings > API Keys
# Publishable key (구 anon key)
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Secret key (구 service_role key)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# CORS 허용 출처 (콤마로 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# 참고: JWT 검증은 JWKS 엔드포인트를 자동으로 사용하므로 JWT_SECRET 불필요
# https://<project-id>.supabase.co/auth/v1/.well-known/jwks.json
